---
import '../styles/global.css';

const SITE = 'https://cotizador.andersonrueda.com';
const TITLE = 'Cotizador — Propuestas económicas para freelancers';
const DESC  = 'Crea cotizaciones personalizadas, calcula totales automáticamente y expórtalas en PDF o PNG. Sin registro, 100% en tu navegador.';
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{TITLE}</title>
    <meta name="description" content={DESC} />
    <meta name="keywords" content="cotizador freelance, propuesta económica, cotización PDF, generador de cotizaciones, presupuesto online, cotización PNG" />
    <meta name="author" content="Anderson Rueda" />
    <link rel="canonical" href={SITE} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={SITE} />
    <meta property="og:title"       content={TITLE} />
    <meta property="og:description" content={DESC} />
    <meta property="og:locale"      content="es_CO" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary" />
    <meta name="twitter:title"       content={TITLE} />
    <meta name="twitter:description" content={DESC} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="app">
      <aside class="panel-side">
        <h1 class="app-title">📄 Cotizador</h1>

        <div class="section">
          <header>Cotización</header>
          <div class="body">
            <div class="row">
              <div style="flex:1">
                <label>N° cotización</label>
                <input id="numero" type="text" />
              </div>
              <div style="flex:1">
                <label>Fecha</label>
                <div style="display:flex;gap:4px;align-items:center;">
                  <input id="fecha" type="text" placeholder="dd-mm-aaaa" style="flex:1;min-width:0;" />
                  <button id="fechaPickerBtn" type="button" class="icon-btn" title="Abrir calendario" style="flex:initial;padding:6px 8px;line-height:1;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  </button>
                  <input id="fechaHidden" type="date" style="display:none;position:absolute;pointer-events:none;" />
                </div>
              </div>
            </div>
            <div>
              <label>Alcance</label>
              <textarea id="alcance" rows="3" placeholder="Modificaciones en el proyecto..."></textarea>
            </div>
            <div class="row" style="align-items:flex-end">
              <div style="flex:1">
                <label>Costo total (COP)</label>
                <input id="costoTotal" type="number" />
              </div>
              <label style="display:flex;align-items:center;gap:6px;flex:initial;text-transform:none;letter-spacing:0;font-size:12px;color:var(--text);margin-bottom:8px">
                <input id="costoAuto" type="checkbox" /> Auto (suma de ítems)
              </label>
            </div>
          </div>
        </div>

        <div class="section">
          <header>Plantilla y colores</header>
          <div class="body">
            <div style="display:none">
              <label>Plantilla</label>
              <select id="plantilla"></select>
            </div>
            <div class="row compact">
              <div class="color-row"><label>Fondo 1</label><input id="colorBg" type="color" /></div>
              <div class="color-row"><label>Fondo 2</label><input id="colorBg2" type="color" /></div>
              <div class="color-row"><label>Acento</label><input id="colorAccent" type="color" /></div>
              <div class="color-row"><label>Texto</label><input id="colorText" type="color" /></div>
            </div>
            <div>
              <label>Logo</label>
              <input id="logoFile" type="file" accept="image/*" style="display:none" />
              <div id="logoArea" class="logo-upload-area" tabindex="0" role="button" title="Click para subir logo">
                <div class="logo-empty-hint">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                  <span>Subir logo</span>
                </div>
                <img id="logoPreview" alt="Logo" style="display:none;max-width:100%;max-height:100%;object-fit:contain;" />
                <button id="logoEditBtn" type="button" class="logo-edit-btn" title="Cambiar logo" style="display:none">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </button>
              </div>
              <button id="logoClear" class="icon-btn logo-clear-btn" style="display:none">✕ Quitar</button>
            </div>
          </div>
        </div>

        <div class="section">
          <header>Ítems</header>
          <div class="body">
            <div class="items-toolbar">
              <div class="items-toolbar-group">
                <span class="toolbar-label">Ordenar</span>
                <button id="sort-precio" class="chip-btn" title="Ordenar por precio">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                  Precio
                </button>
                <button id="sort-titulo" class="chip-btn" title="Ordenar por título">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>
                  Título
                </button>
                <button id="sort-tipo" class="chip-btn" title="Ordenar por tipo">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                  Tipo
                </button>
              </div>
              <button id="toggleAllItems" class="chip-btn chip-btn-outline">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                Colapsar todo
              </button>
            </div>
            <div id="items"></div>
            <button id="addItem">+ Agregar ítem</button>
          </div>
        </div>

        <div class="section collapsed">
          <header>Entrega y términos</header>
          <div class="body">
            <div>
              <label>Tiempo de entrega</label>
              <textarea id="tiempoEntrega" rows="3"></textarea>
            </div>
            <div>
              <label>Términos (una línea por término)</label>
              <textarea id="terminos" rows="3"></textarea>
            </div>
          </div>
        </div>

        <div class="section collapsed">
          <header>Representante legal</header>
          <div class="body">
            <div>
              <label>Nombre</label>
              <input id="repNombre" type="text" />
            </div>
            <div>
              <label>Cédula</label>
              <input id="repCedula" type="text" />
            </div>
            <div>
              <label>Firma (imagen)</label>
              <div class="row">
                <input id="firmaFile" type="file" accept="image/*" style="font-size:11px" />
                <button id="firmaClear" class="icon-btn" style="flex:initial">Quitar</button>
              </div>
              <img id="firmaPreview" style="margin-top:6px;max-width:160px;max-height:60px;background:#fff;border-radius:4px;padding:4px;display:none" />
            </div>
          </div>
        </div>

        <div class="section collapsed">
          <header>Contacto</header>
          <div class="body">
            <div><label>Web</label><input id="cWeb" type="text" /></div>
            <div><label>Email</label><input id="cEmail" type="email" /></div>
            <div><label>Celular</label><input id="cCel" type="text" /></div>
            <div class="row">
              <div style="flex:1"><label>Ciudad</label><input id="cCiudad" type="text" /></div>
              <div style="flex:1"><label>País</label><input id="cPais" type="text" /></div>
            </div>
          </div>
        </div>

        <div class="section collapsed">
          <header>Guardadas</header>
          <div class="body">
            <div id="savedList" class="saved-list"></div>
          </div>
        </div>

        <!-- Input oculto para importar JSON -->
        <input id="importJsonFile" type="file" accept=".json,application/json" style="display:none" />

        <div class="actions-bar">
          <div class="actions-main">
            <button id="saveBtn">💾 Guardar</button>
            <button id="newBtn">＋ Nueva</button>
            <button id="pngBtn">🖼 PNG</button>
            <button id="pdfBtn" class="primary">📄 PDF</button>
          </div>
          <div id="advPanel" class="adv-panel hidden">
            <button id="exportMdBtn" title="Exportar como Markdown">⬇ MD</button>
            <button id="exportJsonBtn" title="Exportar como JSON">⬇ JSON</button>
            <button id="importJsonBtn" title="Importar desde JSON">⬆ JSON</button>
          </div>
          <button id="advToggleBtn" class="adv-toggle" title="Opciones de desarrollo">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            Dev
          </button>
        </div>
      </aside>

      <main class="panel-preview">
        <div class="preview-wrap">
          <canvas id="previewCanvas"></canvas>
        </div>
      </main>
    </div>

    <div id="toast" class="toast"></div>

    <!-- Modal de bienvenida (se oculta si el usuario eligió no volver a mostrar) -->
    <div id="welcomeModal" class="modal-overlay hidden" role="dialog" aria-modal="true" aria-labelledby="welcomeTitle">
      <div class="modal-box">
        <div class="modal-header">
          <svg width="36" height="36" viewBox="0 0 32 32" aria-hidden="true">
            <rect width="32" height="32" rx="7" fill="#1a1d24"/>
            <g transform="translate(6,4) scale(0.83)" stroke="#E8C547" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none">
              <path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1-2-1Z"/>
              <path d="M8 8h8"/><path d="M8 12h8"/><path d="M8 16h5"/>
            </g>
          </svg>
          <div>
            <h2 id="welcomeTitle" class="modal-title">Cotizador</h2>
            <p class="modal-tagline">Propuestas económicas para freelancers</p>
          </div>
        </div>

        <p class="modal-desc">
          Crea cotizaciones personalizadas, calcula totales automáticamente
          y expórtalas en <strong>PDF</strong> o <strong>PNG</strong>.<br />
          Sin registro, sin backend — todo queda en tu navegador.
        </p>

        <div class="modal-links">
          <a href="https://github.com/AndersonDavi/Cotizador" target="_blank" rel="noopener noreferrer" class="modal-link modal-link-gh">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
            ⭐ Star en GitHub
          </a>
          <a href="https://www.linkedin.com/in/anderson-david-rueda-consuegra/" target="_blank" rel="noopener noreferrer" class="modal-link modal-link-li">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>

        <div class="modal-actions">
          <button id="welcomeStart" class="primary modal-start">Empezar →</button>
          <button id="welcomeNever" class="modal-never">No volver a mostrar</button>
        </div>
      </div>
    </div>

    <script>
      import { initEditor } from '../lib/editor';
      initEditor();
    </script>
  </body>
</html>
